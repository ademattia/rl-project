def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument('--n-episodes', default=100, type=int, help='Number of training episodes')
    parser.add_argument('--batch-size', default=5, type=int, help='Batch size for training')
    parser.add_argument('--hidden-dim', default=128, type=int, help='Number of hidden units per layer')
    parser.add_argument('--gamma', default=0.99, type=float, help='Discount factor')
    parser.add_argument('--baseline', default=0.0, type=float, help='Value of the baseline used in REINFORCE')
    parser.add_argument('--verbose', action='store_true', help='Print environment details')
    parser.add_argument('--print-every', default=1000, type=int, help='Print info every <> episodes')
    parser.add_argument('--video-every', default=2000, type=int, help='Record video every <> episodes')
    parser.add_argument('--device', default='cpu', type=str, help='network device [cpu, cuda]')
    parser.add_argument('--seed', default=42, type=int, help='Random seed for reproducibility')

    return parser.parse_args()

args = parse_args()

def print_initialization(env, seed):
    print(f'Seed: {seed}')
    print(f'Action space: {env.action_space}')
    print(f'State space: {env.observation_space}')
    print(f'Dynamics parameters: {env.get_parameters()}')

def print_training_stats(episode, n_episodes, start_time, cumulative_reward, print_every, train_reward, total_steps, episode_steps):
	elapsed = time.time() - start_time 
	avg_reward = cumulative_reward / print_every
	avg_steps = total_steps / print_every
	progress = (episode + 1) / n_episodes * 100
	
	print(f'Episode {episode+1:,} ({progress:.1f}%) | '
			f'Return: {train_reward:.1f} | Steps: {episode_steps} | Reward per Step: {train_reward/episode_steps:.1f} | '
			 f'Avg Return: {avg_reward:.1f} | Avg Steps: {avg_steps:.1f} | Avg Reward per Step: {avg_reward/avg_steps:.1f} |'
			 f'Time: {elapsed/60:.1f}m')

def main():

	env = gym.make('CustomHopper-source-v0', udr = True)
	env.seed(args.seed)
 
	# env = gym.make('CustomHopper-target-v0')

	"""
		Training
	"""
 
	observation_space_dim = env.observation_space.shape[-1]
	action_space_dim = env.action_space.shape[-1]
 
	for episode in range(args.n_episodes):

		state = env.reset()  # Reset the environment and observe the initial state
		print_initialization(env, args.seed)
		done = False
		train_reward = 0
		episode_step = 0

		while not done:  # Loop until the episode is over
      
			previous_state = state

			state, reward, done, info = env.step(env.action_space.sample())

			train_reward += reward
			episode_step += 1
  


if __name__ == '__main__':
	main()